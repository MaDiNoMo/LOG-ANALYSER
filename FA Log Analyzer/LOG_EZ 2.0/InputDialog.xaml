<Window x:Class="LOG_EZ.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Height="180" Width="400" Background="#252526" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="lblPrompt" Text="Enter Value:" Foreground="#E0E0E0" FontWeight="SemiBold" Margin="0,0,0,10"/>
        <TextBox x:Name="txtInput" Grid.Row="1" Background="#1A1A1A" Foreground="#66BB6A" BorderBrush="#3E3E42" CaretBrush="White" Padding="5" VerticalContentAlignment="Center" FontSize="13" BorderThickness="2,2,2,2"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="OK" Click="BtnOk_Click" Width="80" IsDefault="True" Background="#007ACC" Foreground="White" BorderThickness="1,1,1,1" Margin="0,0,10,0" Padding="5"/>
            <Button Content="Cancel" Click="BtnCancel_Click" Width="80" IsCancel="True" Background="#3E3E42" Foreground="#E0E0E0" BorderThickness="1,1,1,1" Padding="5"/>
        </StackPanel>
    </Grid>
</Window>